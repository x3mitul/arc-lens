{
  "name": "arc-lens",
  "displayName": "ARC Lens - Resilient ML Trainer",
  "description": "A real-time PyTorch training dashboard and automated recovery controller built for the ARC framework, featuring weight rollbacks, learning rate adaptation, and AI failure diagnostics.",
  "version": "0.1.3",
  "publisher": "arclens",
  "repository": {
    "type": "git",
    "url": "https://github.com/x3mitul/arc-lens.git"
  },
  "homepage": "https://github.com/x3mitul/arc-lens",
  "bugs": {
    "url": "https://github.com/x3mitul/arc-lens/issues"
  },
  "license": "AGPL-3.0-only",
  "icon": "media/logo.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Machine Learning", "Visualization", "Debuggers"],
  "activationEvents": ["onLanguage:python"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arc-lens.run",
        "title": "▶ Run with ARC Lens",
        "category": "ARC Lens",
        "icon": {
          "light": "media/logo_dark.png",
          "dark": "media/logo_light.png"
        }
      },
      {
        "command": "arc-lens.stop",
        "title": "⏹ Stop ARC Lens",
        "category": "ARC Lens",
        "icon": "$(debug-stop)"
      },
      {
        "command": "arc-lens.openChat",
        "title": "Open AI Failure Analyst",
        "category": "ARC Lens Pro"
      },
      {
        "command": "arc-lens.generateScript",
        "title": "Generate ARC-Tested Script",
        "category": "ARC Lens Pro"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "arc-lens.run",
          "when": "resourceExtname == .py",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "ARC Lens",
      "properties": {
        "arcAgent.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter to use (e.g. /home/user/.venv/bin/python)"
        },
        "arcAgent.stepDelay": {
          "type": "number",
          "default": 0.02,
          "description": "Artificial delay (in seconds) introduced after each training step to pace visualization. Default is 0.02s."
        },
        "arcAgent.licenseKey": {
          "type": "string",
          "default": "",
          "description": "ARC Lens Pro license key. Get yours at https://arc-lens.dev/pro"
        },
        "arcAgent.openRouterKey": {
          "type": "string",
          "default": "",
          "description": "[Pro] Your OpenRouter API key (sk-or-...). Used for AI Failure Analyst and Script Generator."
        },
        "arcAgent.llmModel": {
          "type": "string",
          "default": "google/gemini-2.5-flash:free",
          "description": "[Pro] OpenRouter model string to use for AI features."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && node scripts/embed_python.js",
    "compile": "tsc -p ./ && node scripts/embed_python.js",
    "watch": "tsc -watch -p ./",
    "dev:enable": "node scripts/dev_enable.js",
    "dev:disable": "node scripts/dev_disable.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
